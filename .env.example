# Copy to .env.local and fill. Without these the dashboard runs on MOCK data.

# n8n Cloud REST API — Settings → n8n API → Create API key
N8N_BASE_URL=https://pushagency.app.n8n.cloud
N8N_API_KEY=

# ClickUp personal token (pk_...) — current pipeline state
CLICKUP_TOKEN=
CLICKUP_LIST_ID=901218728372
CLICKUP_TEAM_ID=90121817530

# Google Sheet (Central Activity Log) — published-to-web CSV or Sheets API key
# Easiest: File → Share → Publish to web → CSV link of the log tab
SHEET_CSV_URL=
